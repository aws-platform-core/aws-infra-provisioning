[
    {
      "id": "aws-s3-bucket",
      "name": "AWS S3 Bucket",
      "description": "Provision a secure S3 bucket",
      "category": "storage",
      "parameters": [
        {
          "name": "bucket_name",
          "label": "Bucket Name",
          "type": "string",
          "required": true,
          "placeholder": "my-app-dev-logs"
        },
        {
          "name": "environment",
          "label": "Environment",
          "type": "select",
          "required": true,
          "options": ["dev", "qa", "prod"]
        },
        {
          "name": "versioning",
          "label": "Enable Versioning",
          "type": "boolean",
          "default": true
        }
      ]
    }
  ]